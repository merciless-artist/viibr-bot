# Discord
# Bot token from the Discord Developer Portal.
DISCORD_BOT_TOKEN=
# Prefix for admin/mod text commands. Community features use slash commands.
COMMAND_PREFIX=$

# Database (MySQL / MariaDB)
MYSQL_HOST=
MYSQL_PORT=3306
MYSQL_USER=
MYSQL_PASSWORD=
MYSQL_DATABASE=

# Server and roles
GUILD_ID=
OWNER_ID=
ADMIN_ROLE_ID=
MOD_ROLE_ID=

# Access lists (comma-separated user IDs)
# Managers have owner-level access to every bot function.
MANAGER_IDS=
# Users granted admin access in addition to anyone holding the admin role.
ADMIN_IDS=
# Users granted mod access in addition to anyone holding the mod role.
MOD_IDS=
